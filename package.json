{
  "name": "windows-claude-terminal",
  "version": "1.0.0",
  "description": "A terminal for Windows with built-in Claude Code support",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.claude.terminal",
    "productName": "Claude Terminal",
    "win": {
      "target": "nsis"
    },
    "nativeRebuilder": "sequential"
  }
}
